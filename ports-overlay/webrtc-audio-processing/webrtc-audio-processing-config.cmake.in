@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
find_dependency(absl CONFIG REQUIRED)

get_filename_component(_webrtc_prefix "${CMAKE_CURRENT_LIST_DIR}/../.." ABSOLUTE)
set(_webrtc_include "${_webrtc_prefix}/include/webrtc-audio-processing-1")

add_library(webrtc-audio-processing::webrtc-audio-coding STATIC IMPORTED)
set_target_properties(webrtc-audio-processing::webrtc-audio-coding PROPERTIES
    IMPORTED_CONFIGURATIONS "Debug;Release"
    IMPORTED_LOCATION_RELEASE "${_webrtc_prefix}/lib/webrtc-audio-coding-1.lib"
    IMPORTED_LOCATION_DEBUG   "${_webrtc_prefix}/debug/lib/webrtc-audio-coding-1.lib"
    INTERFACE_INCLUDE_DIRECTORIES "${_webrtc_include}"
)

add_library(webrtc-audio-processing::webrtc-audio-processing STATIC IMPORTED)
set_target_properties(webrtc-audio-processing::webrtc-audio-processing PROPERTIES
    IMPORTED_CONFIGURATIONS "Debug;Release"
    IMPORTED_LOCATION_RELEASE "${_webrtc_prefix}/lib/webrtc-audio-processing-1.lib"
    IMPORTED_LOCATION_DEBUG   "${_webrtc_prefix}/debug/lib/webrtc-audio-processing-1.lib"
    INTERFACE_INCLUDE_DIRECTORIES "${_webrtc_include}"
    INTERFACE_LINK_LIBRARIES "webrtc-audio-processing::webrtc-audio-coding;absl::abseil_dll"
)
